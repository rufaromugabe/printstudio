NEXT_PUBLIC_API_URL=http://localhost:8080
DATABASE_URL=postgres://printstudio:printstudio@localhost:5432/printstudio?sslmode=disable
# Local: AUTH_MODE=dev. Production: AUTH_MODE=jwt with JWT_SECRET (>=32 chars) + Google client IDs.
AUTH_MODE=dev
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
WEB_ORIGIN=http://localhost:3000
VIPS_BIN=
POTRACE_BIN=
# Common profiles (sRGB, Display P3, Gray Gamma 2.2) auto-seed into this directory
ICC_PROFILE_DIR=./data/icc
REQUIRE_PRODUCTION_NATIVES=false
REQUIRE_PRODUCTION_APPROVAL=false
REQUIRE_ICC=false
MAX_RENDER_PIXELS=100000000
DEV_USER_ID=00000000-0000-0000-0000-000000000001
DEV_WORKSPACE_ID=10000000-0000-0000-0000-000000000001
# Cloudflare R2 (S3-compatible) — set real keys in gitignored .env
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_PUBLIC_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=printstudio-assets
GOOGLE_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com
